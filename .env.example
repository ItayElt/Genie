# No API key needed — uses local Ollama (ollama.ai)
# Install Ollama, then run: ollama pull llama3.1:8b
TAVILY_API_KEY=tvly-...

# Email — choose one method:

# Option A: Gmail SMTP (simplest)
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-gmail-app-password   # See README for how to generate

# Option B: SendGrid
SENDGRID_API_KEY=SG...
SENDER_EMAIL=brief@yourdomain.com

# Recipients (comma-separated for multiple)
RECIPIENT_EMAILS=itayeltahan1@gmail.com

# Optional: Unsplash for hero image
UNSPLASH_ACCESS_KEY=your-unsplash-access-key

# Optional: override sender display name
SENDER_NAME=Genie Code PM Brief
